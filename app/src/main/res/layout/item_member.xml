<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="10dp"
    android:background="@drawable/card_background"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="14dp">

    <ImageView
        android:id="@+id/imgProfile"
        android:layout_width="78dp"
        android:layout_height="78dp"
        android:contentDescription="Developer profile photo"
        android:scaleType="centerCrop" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/txtMemberName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/hazard_text"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtMemberDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:textColor="@color/hazard_text_secondary"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/txtMemberTask"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/hazard_blue"
            android:textSize="14sp" />
    </LinearLayout>
</LinearLayout>
